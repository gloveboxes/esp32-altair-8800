# Set target to ESP32-S3
CONFIG_IDF_TARGET="esp32s3"

# Use a custom single-app partition table. Bluetooth support now exceeds
# ESP-IDF's built-in 1500K "large" app slot, and this board has 16 MB flash.
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"

# Enable BLE HID host for Bluetooth keyboard input.
CONFIG_BT_ENABLED=y
CONFIG_BT_CONTROLLER_ENABLED=y
CONFIG_BT_BLUEDROID_ENABLED=y
CONFIG_BT_BLE_ENABLED=y
CONFIG_BT_BLE_42_FEATURES_SUPPORTED=y
CONFIG_BT_GATTC_ENABLE=y
CONFIG_BT_GATTC_NOTIF_REG_MAX=16
# CONFIG_BT_CLASSIC_ENABLED is not set

# Set CPU frequency to 240 MHz
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y

# Disable task watchdog on Core 1 IDLE task
# (Core 1 runs a CPU-intensive emulator that starves IDLE1)
CONFIG_ESP_TASK_WDT_CHECK_IDLE_TASK_CPU1=n

# Set flash size to 16 MB
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y

# Enable USB Serial JTAG console
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y

# Waveshare ESP32-S3 Touch LCD 3.5B has 8 MB Octal PSRAM. Use it for large
# display buffers so SDMMC, WiFi, and WebSocket keep internal RAM available.
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=16384
CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=y
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=32768

# OpenAI HTTPS runs while BLE, WiFi, SDMMC, and the QSPI display are active.
# Put mbedTLS buffers in PSRAM and let TX/RX buffers be allocated only while
# needed so TLS handshakes do not fail when internal DMA-capable RAM is tight.
# CONFIG_MBEDTLS_INTERNAL_MEM_ALLOC is not set
CONFIG_MBEDTLS_EXTERNAL_MEM_ALLOC=y
CONFIG_MBEDTLS_DYNAMIC_BUFFER=y
CONFIG_MBEDTLS_DYNAMIC_FREE_CONFIG_DATA=y

# BLE HID and WiFi both need internal RAM. Keep WiFi throughput modest so
# keyboard pairing, WebSocket terminal, and the emulator can coexist.
# Static RX/TX buffers (1600 B each) must live in internal DMA-capable RAM;
# 8+8 = ~25 KB and was failing to allocate at boot. Drop to 4+4 to free ~12 KB.
CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=4
CONFIG_ESP_WIFI_STATIC_TX_BUFFER_NUM=4
CONFIG_ESP_WIFI_CACHE_TX_BUFFER_NUM=4
CONFIG_ESP_WIFI_MGMT_SBUF_NUM=16
# RX_BA_WIN must be <= 2 * STATIC_RX_BUFFER_NUM (default 16 violates this with RX=4)
CONFIG_ESP_WIFI_RX_BA_WIN=8

# Increase default task stack size
CONFIG_ESP_MAIN_TASK_STACK_SIZE=4096

# Enable WebSocket support in HTTP server
CONFIG_HTTPD_WS_SUPPORT=y

# LwIP socket configuration - sized for two HTTP servers (captive portal + WebSocket)
# HTTP server uses 3 sockets internally, so max_open_sockets must be <= (MAX_SOCKETS - 3)
# Captive portal default is 7, needs 7+3=10 minimum. Add margin for safety.
CONFIG_LWIP_MAX_SOCKETS=16
CONFIG_LWIP_MAX_ACTIVE_TCP=16
CONFIG_LWIP_MAX_LISTENING_TCP=8

# Socket recycling - keep aggressive settings for clean RST closes
CONFIG_LWIP_TCP_MSL=100
CONFIG_LWIP_TCP_FIN_WAIT_TIMEOUT=1000

# Enable socket options for connection control
CONFIG_LWIP_SO_REUSE=y
CONFIG_LWIP_SO_LINGER=y

CONFIG_LWIP_TCP_MSS=1440

# TCP buffer sizes for WebSocket throughput
# Larger buffers reduce EWOULDBLOCK (error 119) during bursts
CONFIG_LWIP_TCP_SND_BUF_DEFAULT=11488
CONFIG_LWIP_TCP_WND_DEFAULT=11488
CONFIG_LWIP_TCP_RECVMBOX_SIZE=12
CONFIG_LWIP_TCP_QUEUE_OOSEQ=y

# Pin LwIP TCP/IP task to Core 0 to keep Core 1 isolated for the emulator
CONFIG_LWIP_TCPIP_TASK_AFFINITY_CPU0=y
CONFIG_LWIP_TCPIP_TASK_AFFINITY_NO_AFFINITY=n
CONFIG_LWIP_TCPIP_TASK_AFFINITY=0x0

# Enable SO_RCVBUF/SO_SNDBUF socket options
CONFIG_LWIP_SO_RCVBUF=y

# --- Crash diagnostics ---
# Print panic backtrace to UART before reboot
CONFIG_ESP_TASK_WDT_PANIC=y
CONFIG_ESP_COREDUMP_ENABLE_TO_UART=y
CONFIG_ESP_COREDUMP_ENABLE_TO_NONE=n
CONFIG_ESP_COREDUMP_DECODE_INFO=y
CONFIG_ESP_COREDUMP_DATA_FORMAT_ELF=y
